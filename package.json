{
  "name": "simplesync",
  "displayName": "SimpleSync",
  "description": "Real-time LAN code sync between VS Code, Cursor, and Windsurf. No internet required.",
  "version": "0.2.0",
  "publisher": "sanket-jivtode",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kizal/SimpleSync.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "sync",
    "lan",
    "local",
    "share",
    "cursor",
    "peer-to-peer",
    "offline"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "simplesync.broadcast",
        "title": "Start Broadcasting",
        "category": "SimpleSync"
      },
      {
        "command": "simplesync.connect",
        "title": "Connect to Session",
        "category": "SimpleSync"
      },
      {
        "command": "simplesync.stop",
        "title": "Stop Broadcasting",
        "category": "SimpleSync"
      },
      {
        "command": "simplesync.pushBack",
        "title": "Push Changes Back",
        "category": "SimpleSync"
      },
      {
        "command": "simplesync.connectManual",
        "title": "Connect Manually (IP:Port)",
        "category": "SimpleSync"
      },
      {
        "command": "simplesync.disconnect",
        "title": "Disconnect",
        "category": "SimpleSync"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "simplesync.broadcast",
          "group": "navigation",
          "when": "explorerViewletVisible"
        },
        {
          "command": "simplesync.pushBack",
          "group": "navigation",
          "when": "simplesync.isReceiver"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "simplesync",
          "title": "SimpleSync",
          "icon": "assets/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "simplesync": [
        {
          "id": "simplesyncPeers",
          "name": "Peers"
        }
      ]
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "npm run build -- --watch",
    "package": "npm run build && vsce package",
    "publish": "npm run build && vsce publish"
  },
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "diff": "^5.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "@types/ws": "^8.5.10",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0"
  }
}
